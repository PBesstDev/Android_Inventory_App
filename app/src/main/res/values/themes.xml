<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- main light/day theme for the app -->
    <style name="Theme.Bessmertnyy_32_Assignment" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- brand primary colors -->
        <item name="colorPrimary">@color/calm_blue_primary</item>
        <item name="colorPrimaryVariant">@color/calm_blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- secondary/accent colors -->
        <item name="colorSecondary">@color/calm_blue_light</item>
        <item name="colorSecondaryVariant">@color/calm_blue_light</item>
        <item name="colorOnSecondary">@color/slate_dark</item>
        <!-- system bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- surface + text colors for backgrounds/content -->
        <item name="android:windowBackground">@color/background_light_gray</item>
        <item name="colorSurface">@color/white</item>
        <item name="android:textColorPrimary">@color/slate_dark</item>
        <item name="android:textColorSecondary">@color/slate_medium</item>
    </style>
</resources>
