<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for displaying the inventory data in a grid/list format -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header bar containing the column labels -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/header_background"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="180dp">

        <!-- Column Label: Item Name -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="@string/inventory_title_item"
            android:textStyle="bold" />

        <!-- Column Label: Quantity -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/inventory_title_qty"
            android:textAlignment="center"
            android:textStyle="bold" />

        <!-- Column Label: Location -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="@string/inventory_title_loc"
            android:textStyle="bold" />

        <!-- Spacer to align with the delete button in data rows -->
        <View
            android:layout_width="48dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Scrollable list of inventory items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewData"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Floating Action Button to add a new entry to the database -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>