<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for viewing the list of available inventories -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Header title for the inventory list -->
    <TextView
        android:id="@+id/tvInventoryHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Available Inventories"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- List view to display available inventory names -->
    <ListView
        android:id="@+id/listViewInventories"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvInventoryHeader" />

</androidx.constraintlayout.widget.ConstraintLayout>